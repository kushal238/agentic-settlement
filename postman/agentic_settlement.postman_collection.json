                  "  } return r;",
                  "};",
                  "const b64dec = s => {",
                  "  var t = '';",
                  "  for (var i = 0; i < s.length; i++) {",
                  "    if (s[i]==='-') t+='+'; else if (s[i]==='_') t+='/'; else t+=s[i];",
                  "  }",
                  "  t += '='.repeat((4 - t.length % 4) % 4);",
