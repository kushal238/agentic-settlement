                  "const sender    = pm.environment.get('SENDER_ID')    || 'sender-1';",
                  "const recipient = pm.environment.get('RECIPIENT_ID') || 'server-recipient';",
                  "const amount    = parseInt(pm.environment.get('PAYMENT_AMOUNT') || '10');",
                  "const nonce     = parseInt(pm.environment.get('CURRENT_NONCE')  || '0');",
                  "const seedB64   = pm.environment.get('SENDER_SEED_B64');",
                  "const pubkeyB64 = pm.environment.get('SENDER_PUBKEY_B64');",
                  "const kp  = nacl.sign.keyPair.fromSeed(b64dec(seedB64));",
                  "const sig = nacl.sign.detached(buildPayload(sender, recipient, amount, nonce), kp.secretKey);",
                  "const body = { sender, recipient, amount, nonce, sender_pubkey: pubkeyB64, signature: b64url(sig) };",
                  "pm.variables.set('X_SETTLE_BODY', JSON.stringify(body, null, 2));"
                ]
              }
            },
