                "type": "text/javascript",
                "exec": [
                  "// Sign a claim with nonce=999 — validators will reject 'nonce mismatch'.",
                  "const nacl = require('tweetnacl');",
                  "const enc = s => new Uint8Array(s.split('').map(c => c.charCodeAt(0)));",
                  "const b64url = bytes => {",
                  "  var s='', r=''; new Uint8Array(bytes).forEach(x => s += String.fromCharCode(x));",
                  "  var t = btoa(s);",
                  "  for (var i = 0; i < t.length; i++) {",
                  "    if (t[i]==='+') r+='-'; else if (t[i]==='/') r+='_'; else if (t[i]!=='=') r+=t[i];",
                  "  } return r;",
                  "};",
                  "const b64dec = s => {",
                  "  var t = '';",
                  "  for (var i = 0; i < s.length; i++) {",
                  "    if (s[i]==='-') t+='+'; else if (s[i]==='_') t+='/'; else t+=s[i];",
                  "  }",
                  "  t += '='.repeat((4 - t.length % 4) % 4);",
                  "  return Uint8Array.from(atob(t), c => c.charCodeAt(0));",
                  "};",
                  "const buildPayload = (s, r, a, n) =>",
                  "  enc([s, r, String(a), String(n)].map(p => p.length + ':' + p).join('|'));",
                  "const sender    = pm.environment.get('SENDER_ID')    || 'sender-1';",
                  "const recipient = pm.environment.get('RECIPIENT_ID') || 'server-recipient';",
                  "const amount    = parseInt(pm.environment.get('PAYMENT_AMOUNT') || '10');",
                  "const nonce     = 999; // deliberately wrong",
                  "const seedB64   = pm.environment.get('SENDER_SEED_B64');",
                  "const pubkeyB64 = pm.environment.get('SENDER_PUBKEY_B64');",
                  "const kp  = nacl.sign.keyPair.fromSeed(b64dec(seedB64));",
                  "const sig = nacl.sign.detached(buildPayload(sender, recipient, amount, nonce), kp.secretKey);",
                  "const body = { sender, recipient, amount, nonce, sender_pubkey: pubkeyB64, signature: b64url(sig) };",
                  "pm.variables.set('X_SETTLE_BODY', JSON.stringify(body, null, 2));"
                ]
              }
