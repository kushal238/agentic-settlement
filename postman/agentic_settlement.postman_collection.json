        {
          "name": "POST /settle — invalid signature → 400",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Build a claim body with an all-zero (garbage) 64-byte signature.",
                  "const enc = s => new Uint8Array(s.split('').map(c => c.charCodeAt(0)));",
                  "const b64url = bytes => {",
                  "  var s='', r=''; new Uint8Array(bytes).forEach(x => s += String.fromCharCode(x));",
                  "  var t = btoa(s);",
                  "  for (var i = 0; i < t.length; i++) {",
                  "    if (t[i]==='+') r+='-'; else if (t[i]==='/') r+='_'; else if (t[i]!=='=') r+=t[i];",
                  "  } return r;",
                  "};",
                  "const sender    = pm.environment.get('SENDER_ID')    || 'sender-1';",
                  "const recipient = pm.environment.get('RECIPIENT_ID') || 'server-recipient';",
                  "const amount    = parseInt(pm.environment.get('PAYMENT_AMOUNT') || '10');",
                  "const nonce     = parseInt(pm.environment.get('CURRENT_NONCE')  || '0');",
                  "const pubkeyB64 = pm.environment.get('SENDER_PUBKEY_B64') || 'AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA';",
                  "const sig = new Uint8Array(64); // all zeros — invalid Ed25519 signature",
                  "const body = { sender, recipient, amount, nonce, sender_pubkey: pubkeyB64, signature: b64url(sig) };",
                  "pm.variables.set('X_SETTLE_BODY', JSON.stringify(body, null, 2));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('signature error', () => pm.expect(pm.response.json().detail.toLowerCase()).to.include('signature'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{{X_SETTLE_BODY}}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{FACILITATOR_URL}}/settle", "host": ["{{FACILITATOR_URL}}"], "path": ["settle"] }
          }
        },
