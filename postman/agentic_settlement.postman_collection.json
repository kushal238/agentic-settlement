            "header": [
              { "key": "X-Payment-Claim",     "value": "{{X_PAYMENT_CLAIM}}" },
              { "key": "X-Payment-Signature", "value": "{{X_PAYMENT_SIG}}" }
            ],
            "url": { "raw": "{{API_URL}}/resource", "host": ["{{API_URL}}"], "path": ["resource"] }
          }
        }
      ]
    }
  ]
}
